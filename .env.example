# ClickUp API Configuration
CLICKUP_API_KEY=your_clickup_api_key_here
CLICKUP_PERFORMANCE_LIST_ID=your_performance_list_id_here
CLICKUP_FINANCIAL_LIST_ID=your_financial_list_id_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Application Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# JWT Secret (for token validation)
JWT_SECRET=your_jwt_secret_here

# Environment
NODE_ENV=development

# ClickUp Custom Field IDs (Performance Module)
# These IDs map to custom fields in your ClickUp performance list
# You can find these IDs by inspecting the ClickUp API response
CLICKUP_FIELD_ALCANCE=
CLICKUP_FIELD_ENGAJAMENTO=
CLICKUP_FIELD_IMPRESSOES=
CLICKUP_FIELD_CLIQUES=
CLICKUP_FIELD_STATUS=
CLICKUP_FIELD_IMAGEM=

# Instagram Business Integration Configuration
# Encryption key for storing Instagram access tokens (32-byte hex string)
INSTAGRAM_ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# Instagram API Configuration
# Optional: URL to external credential vault service
INSTAGRAM_VAULT_URL=

# Sync Job Configuration
# Frequency of automatic Instagram sync in minutes (default: 5, min: 5, max: 60)
INSTAGRAM_SYNC_FREQUENCY_MINUTES=5

# Maximum number of Instagram accounts to process in parallel
INSTAGRAM_MAX_CONCURRENT_ACCOUNTS=3

# Timeout for sync job in seconds (default: 120)
INSTAGRAM_SYNC_TIMEOUT_SECONDS=120

# Rate Limiting Configuration
# Instagram API rate limits
INSTAGRAM_RATE_LIMIT_POSTS_PER_SECOND=10
INSTAGRAM_RATE_LIMIT_METRICS_PER_SECOND=20
INSTAGRAM_RATE_LIMIT_MAX_CONCURRENT_REQUESTS=5

# Cache Configuration
# Cache TTL in seconds (default: 300 = 5 minutes)
INSTAGRAM_CACHE_TTL_SECONDS=300

# Maximum items in cache
INSTAGRAM_CACHE_MAX_SIZE=1000

# Cache strategy: 'LRU' or 'FIFO'
INSTAGRAM_CACHE_STRATEGY=LRU

# Logging Configuration
# Log level: 'debug', 'info', 'warn', 'error'
INSTAGRAM_LOG_LEVEL=info

# Enable detailed logging for debugging
INSTAGRAM_DEBUG_MODE=false

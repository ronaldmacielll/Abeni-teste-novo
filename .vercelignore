# Vercel Ignore File
# Files and directories to exclude from Vercel deployments

# Tests
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
e2e/
coverage/
playwright-report/
test-results/

# Documentation
docs/
*.md
!README.md

# Development files
.env.local
.env.development
.env.test

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Kiro
.kiro/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp

# OS files
.DS_Store
Thumbs.db

# Build artifacts (will be rebuilt)
.next/
out/
dist/
build/

# Dependencies (will be reinstalled)
node_modules/

# Misc
.eslintcache
.prettierignore
